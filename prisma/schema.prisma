// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================
// ENUMS
// =============================

enum StaffRole {
  SUPER_ADMIN
  HOSPITAL_ADMIN
  MUNICIPAL_HEALTH_DIRECTOR
  M_AND_E_OFFICER
  RECORDS_OFFICER
  FRONT_DESK
  DOCTOR
  PHYSICIAN_ASSISTANT
  NURSE
  LAB_TECHNICIAN
  PHARMACIST
  BILLING_OFFICER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  LOCKED
}

enum FacilityType {
  HOSPITAL
  HEALTH_CENTRE
  CHPS_COMPOUND
  CLINIC
  MUNICIPAL_DIRECTORATE
  LABORATORY
  PHARMACY
}

enum DepartmentType {
  ADMINISTRATION
  RECORDS
  OPD
  EMERGENCY
  TRIAGE
  GENERAL_CONSULTATION
  MATERNAL_CHILD_HEALTH
  LABORATORY
  PHARMACY
  BILLING
  PUBLIC_HEALTH
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  SEPARATED
  UNKNOWN
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
  UNKNOWN
}

enum PatientStatus {
  ACTIVE
  DECEASED
  ARCHIVED
}

enum VisitType {
  OPD
  EMERGENCY
  FOLLOW_UP
  MATERNAL_CHILD_HEALTH
  IMMUNIZATION
  LAB_ONLY
  PHARMACY_ONLY
  REFERRAL
}

enum EncounterStatus {
  DRAFT
  IN_PROGRESS
  AWAITING_LAB
  AWAITING_PHARMACY
  COMPLETED
  CANCELLED
}

enum AppointmentStatus {
  SCHEDULED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  MISSED
  RESCHEDULED
}

enum QueueStatus {
  WAITING
  IN_TRIAGE
  WITH_CLINICIAN
  AWAITING_LAB
  AWAITING_PHARMACY
  COMPLETED
  CANCELLED
}

enum TriagePriority {
  ROUTINE
  PRIORITY
  URGENT
  EMERGENCY
}

enum AllergySeverity {
  MILD
  MODERATE
  SEVERE
  UNKNOWN
}

enum LabPriority {
  ROUTINE
  URGENT
  STAT
}

enum LabRequestStatus {
  REQUESTED
  SAMPLE_COLLECTED
  PROCESSING
  PARTIAL_RESULT
  COMPLETED
  CANCELLED
}

enum SampleStatus {
  PENDING_COLLECTION
  COLLECTED
  RECEIVED
  REJECTED
  PROCESSING
  STORED
  DISPOSED
}

enum LabResultStatus {
  DRAFT
  ENTERED
  VALIDATED
  RELEASED
  REJECTED
}

enum PrescriptionStatus {
  DRAFT
  ISSUED
  PARTIALLY_DISPENSED
  DISPENSED
  CANCELLED
}

enum DispenseStatus {
  PENDING
  PARTIAL
  COMPLETED
  CANCELLED
}

enum StockMovementType {
  OPENING_BALANCE
  PURCHASE
  DONATION
  ADJUSTMENT_IN
  DISPENSE
  TRANSFER_OUT
  TRANSFER_IN
  EXPIRED
  DAMAGED
  ADJUSTMENT_OUT
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  REVERSED
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  CARD
  BANK_TRANSFER
  NHIS
  WAIVER
  OTHER
}

enum ReferralStatus {
  DRAFT
  SENT
  RECEIVED
  ACCEPTED
  COMPLETED
  REJECTED
  CANCELLED
}

enum MessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationType {
  APPOINTMENT
  LAB_RESULT
  CRITICAL_ALERT
  REFERRAL
  MESSAGE
  SYSTEM
  BILLING
  STOCK
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum DocumentType {
  REFERRAL_NOTE
  LAB_ATTACHMENT
  SCANNED_RECORD
  CONSENT_FORM
  INSURANCE_DOCUMENT
  OTHER
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  PRINT
  APPROVE
  REJECT
  DISPENSE
  VALIDATE
  SEND
}

enum ReportType {
  MORBIDITY
  IMMUNIZATION
  LABORATORY
  PHARMACY
  APPOINTMENT
  FINANCIAL
  HMIS
  AUDIT
  CUSTOM
}

enum SyncStatus {
  PENDING
  PROCESSING
  SYNCED
  FAILED
  CONFLICT
}

// =============================
// ACCESS CONTROL & STAFF
// =============================

model User {
  id           String     @id @default(cuid())
  staffId      String     @unique
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  otherNames   String?
  phone        String?
  jobTitle     String?
  defaultRole  StaffRole
  status       UserStatus @default(ACTIVE)

  facilityId   String
  departmentId String?

  lastLoginAt       DateTime?
  passwordChangedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  facility   Facility    @relation("FacilityStaff", fields: [facilityId], references: [id])
  department Department? @relation("DepartmentStaff", fields: [departmentId], references: [id], onDelete: SetNull)

  roles                       UserRole[]
  sessions                    UserSession[]
  authSessions                Session[]
  appointmentsAsClinician     Appointment[]        @relation("AppointmentClinician")
  createdAppointments         Appointment[]        @relation("AppointmentCreatedBy")
  updatedAppointments         Appointment[]        @relation("AppointmentUpdatedBy")
  encountersAsClinician       Encounter[]          @relation("EncounterClinician")
  registeredPatients          Patient[]            @relation("PatientRegisteredBy")
  recordedAllergies           PatientAllergy[]     @relation("AllergyRecordedBy")
  recordedChronicConditions   ChronicCondition[]   @relation("ChronicConditionRecordedBy")
  recordedMedicationHistories MedicationHistory[]  @relation("MedicationHistoryRecordedBy")
  uploadedPatientDocuments    PatientDocument[]    @relation("PatientDocumentUploadedBy")
  administeredImmunizations   ImmunizationRecord[] @relation("ImmunizationAdministeredBy")
  capturedVitalSigns          VitalSigns[]         @relation("VitalSignsCapturedBy")
  authoredClinicalNotes       ClinicalNote[]       @relation("ClinicalNoteAuthoredBy")
  diagnosesMade               Diagnosis[]          @relation("DiagnosisDiagnosedBy")
  requestedLabRequests        LabRequest[]         @relation("LabRequestRequestedBy")
  collectedLabSamples         LabSample[]          @relation("LabSampleCollectedBy")
  receivedLabSamples          LabSample[]          @relation("LabSampleReceivedBy")
  enteredLabResults           LabResult[]          @relation("LabResultEnteredBy")
  validatedLabResults         LabResult[]          @relation("LabResultValidatedBy")
  prescriptionsPrescribed     Prescription[]       @relation("PrescriptionPrescribedBy")
  stockMovementsPerformed     StockMovement[]      @relation("StockMovementPerformedBy")
  dispensingsPerformed        Dispensing[]         @relation("DispensingDispensedBy")
  createdInvoices             Invoice[]            @relation("InvoiceCreatedBy")
  receivedPayments            Payment[]            @relation("PaymentReceivedBy")
  referralsMade               Referral[]           @relation("ReferralReferredBy")
  referralsReceived           Referral[]           @relation("ReferralReceivedBy")
  assignedQueueEntries        PatientQueue[]       @relation("QueueAssignedTo")
  messageParticipants         MessageParticipant[]
  createdMessageThreads       MessageThread[]      @relation("MessageThreadCreatedBy")
  sentMessages                Message[]            @relation("SentMessages")
  notifications               Notification[]       @relation("UserNotifications")
  createdNotifications        Notification[]       @relation("NotificationCreatedBy")
  auditLogs                   AuditLog[]           @relation("AuditActor")
  generatedReports            ReportExport[]       @relation("ReportGeneratedBy")
  updatedSystemSettings       SystemSetting[]      @relation("SystemSettingUpdatedBy")

  name          String
  emailVerified Boolean   @default(false)
  image         String?
  accounts      Account[]

  @@index([facilityId])
  @@index([departmentId])
  @@index([defaultRole])
  @@index([status])
  @@map("user")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  module      String
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@index([module])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model UserSession {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// =============================
// FACILITY & DEPARTMENTS
// =============================

model Facility {
  id           String       @id @default(cuid())
  code         String       @unique
  name         String
  type         FacilityType @default(HOSPITAL)
  phone        String?
  email        String?
  address      String?
  municipality String?      @default("Kwadaso")
  region       String?      @default("Ashanti")
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  departments        Department[]      @relation("FacilityDepartments")
  staff              User[]            @relation("FacilityStaff")
  registeredPatients Patient[]         @relation("RegisteredFacility")
  appointments       Appointment[]     @relation("FacilityAppointments")
  encounters         Encounter[]       @relation("FacilityEncounters")
  medicationStocks   MedicationStock[]
  invoices           Invoice[]         @relation("FacilityInvoices")
  fromReferrals      Referral[]        @relation("ReferralFromFacility")
  toReferrals        Referral[]        @relation("ReferralToFacility")
  reportExports      ReportExport[]
  notifications      Notification[]    @relation("FacilityNotifications")
  offlineSyncJobs    OfflineSyncJob[]

  @@index([type])
  @@index([isActive])
}

model Department {
  id          String         @id @default(cuid())
  facilityId  String
  code        String
  name        String
  description String?
  type        DepartmentType @default(OTHER)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  facility      Facility       @relation("FacilityDepartments", fields: [facilityId], references: [id], onDelete: Cascade)
  staff         User[]         @relation("DepartmentStaff")
  appointments  Appointment[]  @relation("DepartmentAppointments")
  encounters    Encounter[]    @relation("DepartmentEncounters")
  queues        PatientQueue[] @relation("DepartmentQueues")
  notifications Notification[] @relation("DepartmentNotifications")
  fromReferrals Referral[]     @relation("ReferralFromDepartment")
  toReferrals   Referral[]     @relation("ReferralToDepartment")

  @@unique([facilityId, code])
  @@index([facilityId])
  @@index([type])
  @@index([isActive])
}

// =============================
// PATIENT RECORDS / EHR
// =============================

model Patient {
  id                       String        @id @default(cuid())
  patientNo                String        @unique
  nhisNumber               String?       @unique
  nationalIdNumber         String?       @unique
  firstName                String
  lastName                 String
  otherNames               String?
  gender                   Gender
  dateOfBirth              DateTime?
  estimatedAge             Int?
  maritalStatus            MaritalStatus @default(UNKNOWN)
  bloodGroup               BloodGroup    @default(UNKNOWN)
  occupation               String?
  phone                    String?
  email                    String?
  residentialAddress       String?
  community                String?
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  status                   PatientStatus @default(ACTIVE)

  registeredFacilityId String
  registeredById       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  registeredFacility Facility @relation("RegisteredFacility", fields: [registeredFacilityId], references: [id])
  registeredBy       User?    @relation("PatientRegisteredBy", fields: [registeredById], references: [id], onDelete: SetNull)

  appointments      Appointment[]
  queueEntries      PatientQueue[]
  encounters        Encounter[]
  vitalSigns        VitalSigns[]
  clinicalNotes     ClinicalNote[]
  diagnoses         Diagnosis[]
  allergies         PatientAllergy[]
  chronicConditions ChronicCondition[]
  medicationHistory MedicationHistory[]
  immunizations     ImmunizationRecord[]
  documents         PatientDocument[]
  prescriptions     Prescription[]
  labRequests       LabRequest[]
  labResults        LabResult[]
  dispensings       Dispensing[]
  invoices          Invoice[]
  referrals         Referral[]
  messageThreads    MessageThread[]      @relation("PatientThreads")

  @@index([registeredFacilityId])
  @@index([registeredById])
  @@index([lastName, firstName])
  @@index([phone])
  @@index([status])
}

model PatientAllergy {
  id           String          @id @default(cuid())
  patientId    String
  allergen     String
  reaction     String?
  severity     AllergySeverity @default(UNKNOWN)
  notes        String?
  recordedById String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  patient    Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recordedBy User?   @relation("AllergyRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([recordedById])
  @@index([severity])
}

model ChronicCondition {
  id           String    @id @default(cuid())
  patientId    String
  name         String
  diagnosedAt  DateTime?
  status       String?   @default("Active")
  notes        String?
  recordedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  patient    Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recordedBy User?   @relation("ChronicConditionRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([recordedById])
  @@index([name])
}

model MedicationHistory {
  id             String    @id @default(cuid())
  patientId      String
  medicationName String
  dosage         String?
  frequency      String?
  startDate      DateTime?
  endDate        DateTime?
  notes          String?
  recordedById   String?
  createdAt      DateTime  @default(now())

  patient    Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recordedBy User?   @relation("MedicationHistoryRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([recordedById])
}

model PatientDocument {
  id           String       @id @default(cuid())
  patientId    String
  type         DocumentType @default(OTHER)
  title        String
  fileUrl      String
  fileName     String?
  mimeType     String?
  sizeBytes    Int?
  uploadedById String?
  createdAt    DateTime     @default(now())

  patient    Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation("PatientDocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([uploadedById])
  @@index([type])
}

model ImmunizationRecord {
  id               String    @id @default(cuid())
  patientId        String
  vaccineName      String
  dose             String?
  batchNumber      String?
  administeredAt   DateTime
  nextDueAt        DateTime?
  administeredById String?
  notes            String?
  createdAt        DateTime  @default(now())

  patient        Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  administeredBy User?   @relation("ImmunizationAdministeredBy", fields: [administeredById], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([administeredById])
  @@index([vaccineName])
  @@index([administeredAt])
}

// =============================
// APPOINTMENTS, QUEUE & TRIAGE
// =============================

model Appointment {
  id                 String            @id @default(cuid())
  appointmentNo      String            @unique
  patientId          String
  facilityId         String
  departmentId       String?
  clinicianId        String?
  title              String?
  reason             String?
  notes              String?
  scheduledAt        DateTime
  durationMinutes    Int               @default(30)
  status             AppointmentStatus @default(SCHEDULED)
  checkedInAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  createdById        String?
  updatedById        String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  patient      Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  facility     Facility       @relation("FacilityAppointments", fields: [facilityId], references: [id])
  department   Department?    @relation("DepartmentAppointments", fields: [departmentId], references: [id], onDelete: SetNull)
  clinician    User?          @relation("AppointmentClinician", fields: [clinicianId], references: [id], onDelete: SetNull)
  createdBy    User?          @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?          @relation("AppointmentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  queueEntries PatientQueue[]
  encounter    Encounter?     @relation("AppointmentEncounter")

  @@index([patientId])
  @@index([facilityId])
  @@index([departmentId])
  @@index([clinicianId])
  @@index([createdById])
  @@index([updatedById])
  @@index([scheduledAt])
  @@index([status])
}

model PatientQueue {
  id                 String         @id @default(cuid())
  queueNo            String
  patientId          String
  appointmentId      String?
  departmentId       String
  assignedToId       String?
  priority           TriagePriority @default(ROUTINE)
  status             QueueStatus    @default(WAITING)
  arrivedAt          DateTime       @default(now())
  calledAt           DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  reason             String?
  notes              String?

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  department  Department   @relation("DepartmentQueues", fields: [departmentId], references: [id])
  assignedTo  User?        @relation("QueueAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  encounter   Encounter?   @relation("QueueEncounter")

  @@unique([departmentId, queueNo, arrivedAt])
  @@index([patientId])
  @@index([appointmentId])
  @@index([departmentId])
  @@index([assignedToId])
  @@index([status])
  @@index([priority])
}

model VitalSigns {
  id               String         @id @default(cuid())
  patientId        String
  encounterId      String?
  temperatureC     Decimal?       @db.Decimal(5, 2)
  systolicBp       Int?
  diastolicBp      Int?
  pulseRate        Int?
  respiratoryRate  Int?
  oxygenSaturation Int?
  weightKg         Decimal?       @db.Decimal(7, 2)
  heightCm         Decimal?       @db.Decimal(7, 2)
  bmi              Decimal?       @db.Decimal(5, 2)
  painScore        Int?
  triagePriority   TriagePriority @default(ROUTINE)
  notes            String?
  capturedById     String?
  capturedAt       DateTime       @default(now())

  patient    Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter  Encounter? @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  capturedBy User?      @relation("VitalSignsCapturedBy", fields: [capturedById], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([encounterId])
  @@index([capturedById])
  @@index([capturedAt])
  @@index([triagePriority])
}

// =============================
// CLINICAL ENCOUNTERS
// =============================

model Encounter {
  id             String          @id @default(cuid())
  encounterNo    String          @unique
  patientId      String
  appointmentId  String?         @unique
  facilityId     String
  departmentId   String
  clinicianId    String?
  queueId        String?         @unique
  visitType      VisitType       @default(OPD)
  status         EncounterStatus @default(DRAFT)
  chiefComplaint String?
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  patient     Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment?  @relation("AppointmentEncounter", fields: [appointmentId], references: [id], onDelete: SetNull)
  facility    Facility      @relation("FacilityEncounters", fields: [facilityId], references: [id])
  department  Department    @relation("DepartmentEncounters", fields: [departmentId], references: [id])
  clinician   User?         @relation("EncounterClinician", fields: [clinicianId], references: [id], onDelete: SetNull)
  queue       PatientQueue? @relation("QueueEncounter", fields: [queueId], references: [id], onDelete: SetNull)

  vitalSigns     VitalSigns[]
  clinicalNotes  ClinicalNote[]
  diagnoses      Diagnosis[]
  prescriptions  Prescription[]
  labRequests    LabRequest[]
  labResults     LabResult[]
  invoices       Invoice[]
  referrals      Referral[]
  messageThreads MessageThread[] @relation("EncounterThreads")

  @@index([patientId])
  @@index([facilityId])
  @@index([departmentId])
  @@index([clinicianId])
  @@index([queueId])
  @@index([status])
  @@index([startedAt])
}

model ClinicalNote {
  id           String    @id @default(cuid())
  patientId    String
  encounterId  String
  subjective   String?
  objective    String?
  assessment   String?
  plan         String?
  notes        String?
  authoredById String?
  signedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  patient    Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter  Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  authoredBy User?     @relation("ClinicalNoteAuthoredBy", fields: [authoredById], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([encounterId])
  @@index([authoredById])
  @@index([createdAt])
}

model Diagnosis {
  id            String   @id @default(cuid())
  patientId     String
  encounterId   String
  code          String?
  name          String
  isPrimary     Boolean  @default(false)
  notes         String?
  diagnosedById String?
  createdAt     DateTime @default(now())

  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter   Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  diagnosedBy User?     @relation("DiagnosisDiagnosedBy", fields: [diagnosedById], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([encounterId])
  @@index([diagnosedById])
  @@index([code])
  @@index([name])
}

// =============================
// LABORATORY MANAGEMENT
// =============================

model LabTestCatalog {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  category        String?
  sampleType      String?
  unit            String?
  referenceRange  String?
  price           Decimal? @db.Decimal(12, 2)
  turnaroundHours Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requestTests LabRequestTest[]
  results      LabResult[]

  @@index([name])
  @@index([category])
  @@index([isActive])
}

model LabRequest {
  id                 String           @id @default(cuid())
  requestNo          String           @unique
  patientId          String
  encounterId        String?
  requestedById      String?
  priority           LabPriority      @default(ROUTINE)
  status             LabRequestStatus @default(REQUESTED)
  clinicalNotes      String?
  requestedAt        DateTime         @default(now())
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  patient     Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter   Encounter?       @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  requestedBy User?            @relation("LabRequestRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  tests       LabRequestTest[]
  samples     LabSample[]

  @@index([patientId])
  @@index([encounterId])
  @@index([requestedById])
  @@index([priority])
  @@index([status])
  @@index([requestedAt])
}

model LabRequestTest {
  id           String   @id @default(cuid())
  labRequestId String
  testId       String
  notes        String?
  createdAt    DateTime @default(now())

  labRequest LabRequest     @relation(fields: [labRequestId], references: [id], onDelete: Cascade)
  test       LabTestCatalog @relation(fields: [testId], references: [id])
  result     LabResult?

  @@unique([labRequestId, testId])
  @@index([labRequestId])
  @@index([testId])
}

model LabSample {
  id              String       @id @default(cuid())
  sampleNo        String       @unique
  labRequestId    String
  sampleType      String
  status          SampleStatus @default(PENDING_COLLECTION)
  collectedById   String?
  collectedAt     DateTime?
  receivedById    String?
  receivedAt      DateTime?
  rejectionReason String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  labRequest  LabRequest @relation(fields: [labRequestId], references: [id], onDelete: Cascade)
  collectedBy User?      @relation("LabSampleCollectedBy", fields: [collectedById], references: [id], onDelete: SetNull)
  receivedBy  User?      @relation("LabSampleReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)

  @@index([labRequestId])
  @@index([collectedById])
  @@index([receivedById])
  @@index([status])
  @@index([collectedAt])
}

model LabResult {
  id               String          @id @default(cuid())
  resultNo         String          @unique
  labRequestTestId String          @unique
  patientId        String
  encounterId      String?
  testId           String
  status           LabResultStatus @default(DRAFT)
  resultText       String?
  abnormalFlag     Boolean         @default(false)
  criticalFlag     Boolean         @default(false)
  enteredById      String?
  enteredAt        DateTime?
  validatedById    String?
  validatedAt      DateTime?
  releasedAt       DateTime?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  requestTest LabRequestTest  @relation(fields: [labRequestTestId], references: [id], onDelete: Cascade)
  patient     Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter   Encounter?      @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  test        LabTestCatalog  @relation(fields: [testId], references: [id])
  enteredBy   User?           @relation("LabResultEnteredBy", fields: [enteredById], references: [id], onDelete: SetNull)
  validatedBy User?           @relation("LabResultValidatedBy", fields: [validatedById], references: [id], onDelete: SetNull)
  items       LabResultItem[]

  @@index([patientId])
  @@index([encounterId])
  @@index([testId])
  @@index([enteredById])
  @@index([validatedById])
  @@index([status])
  @@index([criticalFlag])
}

model LabResultItem {
  id             String   @id @default(cuid())
  labResultId    String
  parameterName  String
  value          String?
  unit           String?
  referenceRange String?
  isAbnormal     Boolean  @default(false)
  createdAt      DateTime @default(now())

  labResult LabResult @relation(fields: [labResultId], references: [id], onDelete: Cascade)

  @@index([labResultId])
}

// =============================
// PHARMACY & PRESCRIPTIONS
// =============================

model Medication {
  id           String   @id @default(cuid())
  code         String?  @unique
  name         String
  genericName  String?
  category     String?
  dosageForm   String?
  strength     String?
  unit         String?
  reorderLevel Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stocks            MedicationStock[]
  stockMovements    StockMovement[]
  prescriptionItems PrescriptionItem[]
  dispenseItems     DispenseItem[]

  @@index([name])
  @@index([genericName])
  @@index([isActive])
}

model Prescription {
  id             String             @id @default(cuid())
  prescriptionNo String             @unique
  patientId      String
  encounterId    String?
  prescribedById String?
  status         PrescriptionStatus @default(DRAFT)
  notes          String?
  issuedAt       DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  patient      Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter    Encounter?         @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  prescribedBy User?              @relation("PrescriptionPrescribedBy", fields: [prescribedById], references: [id], onDelete: SetNull)
  items        PrescriptionItem[]
  dispensing   Dispensing?

  @@index([patientId])
  @@index([encounterId])
  @@index([prescribedById])
  @@index([status])
  @@index([issuedAt])
}

model PrescriptionItem {
  id             String   @id @default(cuid())
  prescriptionId String
  medicationId   String?
  medicineName   String
  dosage         String?
  frequency      String?
  duration       String?
  quantity       Int?
  instructions   String?
  createdAt      DateTime @default(now())

  prescription  Prescription   @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medication    Medication?    @relation(fields: [medicationId], references: [id], onDelete: SetNull)
  dispenseItems DispenseItem[]

  @@index([prescriptionId])
  @@index([medicationId])
}

model MedicationStock {
  id             String    @id @default(cuid())
  facilityId     String
  medicationId   String
  batchNumber    String?
  expiryDate     DateTime?
  quantityOnHand Int       @default(0)
  unitCost       Decimal?  @db.Decimal(12, 2)
  sellingPrice   Decimal?  @db.Decimal(12, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  facility   Facility        @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  medication Medication      @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  movements  StockMovement[]

  @@unique([facilityId, medicationId, batchNumber])
  @@index([facilityId])
  @@index([medicationId])
  @@index([expiryDate])
}

model StockMovement {
  id            String            @id @default(cuid())
  stockId       String
  medicationId  String
  type          StockMovementType
  quantity      Int
  reason        String?
  reference     String?
  performedById String?
  createdAt     DateTime          @default(now())

  stock       MedicationStock @relation(fields: [stockId], references: [id], onDelete: Cascade)
  medication  Medication      @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  performedBy User?           @relation("StockMovementPerformedBy", fields: [performedById], references: [id], onDelete: SetNull)

  @@index([stockId])
  @@index([medicationId])
  @@index([performedById])
  @@index([type])
  @@index([createdAt])
}

model Dispensing {
  id               String         @id @default(cuid())
  dispenseNo       String         @unique
  prescriptionId   String         @unique
  patientId        String
  status           DispenseStatus @default(PENDING)
  dispensedById    String?
  dispensedAt      DateTime?
  counsellingNotes String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  prescription Prescription   @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  patient      Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  dispensedBy  User?          @relation("DispensingDispensedBy", fields: [dispensedById], references: [id], onDelete: SetNull)
  items        DispenseItem[]

  @@index([patientId])
  @@index([dispensedById])
  @@index([status])
  @@index([dispensedAt])
}

model DispenseItem {
  id                 String   @id @default(cuid())
  dispensingId       String
  prescriptionItemId String?
  medicationId       String?
  medicineName       String
  quantityDispensed  Int
  notes              String?
  createdAt          DateTime @default(now())

  dispensing       Dispensing        @relation(fields: [dispensingId], references: [id], onDelete: Cascade)
  prescriptionItem PrescriptionItem? @relation(fields: [prescriptionItemId], references: [id], onDelete: SetNull)
  medication       Medication?       @relation(fields: [medicationId], references: [id], onDelete: SetNull)

  @@index([dispensingId])
  @@index([prescriptionItemId])
  @@index([medicationId])
}

// =============================
// BILLING & PAYMENTS
// =============================

model Invoice {
  id             String        @id @default(cuid())
  invoiceNo      String        @unique
  patientId      String
  encounterId    String?
  facilityId     String
  status         InvoiceStatus @default(DRAFT)
  subtotal       Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal       @default(0) @db.Decimal(12, 2)
  amountPaid     Decimal       @default(0) @db.Decimal(12, 2)
  balanceDue     Decimal       @default(0) @db.Decimal(12, 2)
  issuedAt       DateTime?
  createdById    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  patient   Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter Encounter?    @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  facility  Facility      @relation("FacilityInvoices", fields: [facilityId], references: [id])
  createdBy User?         @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items     InvoiceItem[]
  payments  Payment[]

  @@index([patientId])
  @@index([encounterId])
  @@index([facilityId])
  @@index([createdById])
  @@index([status])
  @@index([issuedAt])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  itemType    String?
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  totalPrice  Decimal  @db.Decimal(12, 2)
  referenceId String?
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([itemType])
}

model Payment {
  id           String        @id @default(cuid())
  receiptNo    String        @unique
  invoiceId    String
  method       PaymentMethod
  status       PaymentStatus @default(PENDING)
  amount       Decimal       @db.Decimal(12, 2)
  reference    String?
  receivedById String?
  paidAt       DateTime?
  createdAt    DateTime      @default(now())

  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  receivedBy User?   @relation("PaymentReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([receivedById])
  @@index([method])
  @@index([status])
  @@index([paidAt])
}

// =============================
// REFERRALS, MESSAGING & NOTIFICATIONS
// =============================

model Referral {
  id               String         @id @default(cuid())
  referralNo       String         @unique
  patientId        String
  encounterId      String?
  fromFacilityId   String
  toFacilityId     String?
  fromDepartmentId String?
  toDepartmentId   String?
  referredById     String?
  receivedById     String?
  reason           String
  clinicalSummary  String?
  urgency          TriagePriority @default(ROUTINE)
  status           ReferralStatus @default(DRAFT)
  sentAt           DateTime?
  receivedAt       DateTime?
  completedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  patient        Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  encounter      Encounter?  @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  fromFacility   Facility    @relation("ReferralFromFacility", fields: [fromFacilityId], references: [id])
  toFacility     Facility?   @relation("ReferralToFacility", fields: [toFacilityId], references: [id], onDelete: SetNull)
  fromDepartment Department? @relation("ReferralFromDepartment", fields: [fromDepartmentId], references: [id], onDelete: SetNull)
  toDepartment   Department? @relation("ReferralToDepartment", fields: [toDepartmentId], references: [id], onDelete: SetNull)
  referredBy     User?       @relation("ReferralReferredBy", fields: [referredById], references: [id], onDelete: SetNull)
  receivedBy     User?       @relation("ReferralReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([encounterId])
  @@index([fromFacilityId])
  @@index([toFacilityId])
  @@index([fromDepartmentId])
  @@index([toDepartmentId])
  @@index([referredById])
  @@index([receivedById])
  @@index([status])
  @@index([urgency])
}

model MessageThread {
  id          String          @id @default(cuid())
  subject     String
  patientId   String?
  encounterId String?
  priority    MessagePriority @default(NORMAL)
  isClosed    Boolean         @default(false)
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  patient      Patient?             @relation("PatientThreads", fields: [patientId], references: [id], onDelete: SetNull)
  encounter    Encounter?           @relation("EncounterThreads", fields: [encounterId], references: [id], onDelete: SetNull)
  createdBy    User?                @relation("MessageThreadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  participants MessageParticipant[]
  messages     Message[]

  @@index([patientId])
  @@index([encounterId])
  @@index([createdById])
  @@index([priority])
  @@index([isClosed])
}

model MessageParticipant {
  id         String    @id @default(cuid())
  threadId   String
  userId     String
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId])
}

model Message {
  id            String   @id @default(cuid())
  threadId      String
  senderId      String?
  body          String
  attachmentUrl String?
  sentAt        DateTime @default(now())

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User?         @relation("SentMessages", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([threadId])
  @@index([senderId])
  @@index([sentAt])
}

model Notification {
  id                 String             @id @default(cuid())
  recipientId        String?
  facilityId         String?
  createdById        String?
  targetRole         StaffRole?
  targetDepartmentId String?
  type               NotificationType
  priority           MessagePriority    @default(NORMAL)
  status             NotificationStatus @default(UNREAD)
  title              String
  body               String?
  actionUrl          String?
  entityType         String?
  entityId           String?
  readAt             DateTime?
  expiresAt          DateTime?
  createdAt          DateTime           @default(now())

  recipient        User?       @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  facility         Facility?   @relation("FacilityNotifications", fields: [facilityId], references: [id], onDelete: Cascade)
  createdBy        User?       @relation("NotificationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  targetDepartment Department? @relation("DepartmentNotifications", fields: [targetDepartmentId], references: [id], onDelete: SetNull)

  @@index([recipientId])
  @@index([facilityId])
  @@index([createdById])
  @@index([targetDepartmentId])
  @@index([targetRole])
  @@index([type])
  @@index([priority])
  @@index([status])
  @@index([createdAt])
}

// =============================
// REPORTING, AUDIT & SYSTEM
// =============================

model ReportExport {
  id            String     @id @default(cuid())
  type          ReportType
  title         String
  facilityId    String?
  generatedById String?
  parameters    Json?
  fileUrl       String?
  rowCount      Int?
  status        String     @default("REQUESTED")
  dateFrom      DateTime?
  dateTo        DateTime?
  generatedAt   DateTime   @default(now())

  facility    Facility? @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  generatedBy User?     @relation("ReportGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([facilityId])
  @@index([generatedById])
  @@index([status])
  @@index([dateFrom])
  @@index([dateTo])
  @@index([generatedAt])
}

model AuditLog {
  id          String      @id @default(cuid())
  actorId     String?
  action      AuditAction
  entityType  String
  entityId    String?
  description String?
  before      Json?
  after       Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model OfflineSyncJob {
  id           String     @id @default(cuid())
  facilityId   String?
  deviceId     String?
  entityType   String
  entityId     String?
  operation    String
  payload      Json
  status       SyncStatus @default(PENDING)
  conflictData Json?
  errorMessage String?
  attemptedAt  DateTime?
  syncedAt     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  facility Facility? @relation(fields: [facilityId], references: [id], onDelete: SetNull)

  @@index([facilityId])
  @@index([status])
  @@index([entityType])
  @@index([createdAt])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  isPublic    Boolean  @default(false)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updatedBy User? @relation("SystemSettingUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedById])
  @@index([isPublic])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
